{
  "name": "abstractive-scm",
  "displayName": "Abstractive SCM",
  "description": "IntelliJ-inspired SCM workflows for VS Code: richer Git changes, branches, log, diffs, and commit actions.",
  "version": "0.1.4",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:abstractiveScm.refresh",
    "onCommand:abstractiveScm.toggleTreeView",
    "onCommand:abstractiveScm.openToolWindow",
    "onView:abstractiveScm.changes",
    "onView:abstractiveScm.branches",
    "onView:abstractiveScm.log",
    "onView:abstractiveScm.stashes",
    "onView:abstractiveScm.toolWindow"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "abstractiveScm.refresh",
        "title": "Refresh",
        "category": "Abstractive SCM",
        "icon": "$(refresh)"
      },
      {
        "command": "abstractiveScm.toggleTreeView",
        "title": "Toggle Tree/Flat View",
        "category": "Abstractive SCM",
        "icon": "$(list-tree)"
      },
      {
        "command": "abstractiveScm.stage",
        "title": "Stage",
        "category": "Abstractive SCM",
        "icon": "$(add)"
      },
      {
        "command": "abstractiveScm.stageAll",
        "title": "Stage All",
        "category": "Abstractive SCM",
        "icon": "$(check-all)"
      },
      {
        "command": "abstractiveScm.stageGroup",
        "title": "Stage Group",
        "category": "Abstractive SCM",
        "icon": "$(add)"
      },
      {
        "command": "abstractiveScm.unstage",
        "title": "Unstage",
        "category": "Abstractive SCM",
        "icon": "$(remove)"
      },
      {
        "command": "abstractiveScm.unstageAll",
        "title": "Unstage All",
        "category": "Abstractive SCM",
        "icon": "$(circle-slash)"
      },
      {
        "command": "abstractiveScm.unstageGroup",
        "title": "Unstage Group",
        "category": "Abstractive SCM",
        "icon": "$(remove)"
      },
      {
        "command": "abstractiveScm.revert",
        "title": "Rollback",
        "category": "Abstractive SCM",
        "icon": "$(discard)"
      },
      {
        "command": "abstractiveScm.commit",
        "title": "Commit...",
        "category": "Abstractive SCM",
        "icon": "$(git-commit)"
      },
      {
        "command": "abstractiveScm.amendCommit",
        "title": "Amend Commit...",
        "category": "Abstractive SCM",
        "icon": "$(git-commit)"
      },
      {
        "command": "abstractiveScm.fetch",
        "title": "Fetch",
        "category": "Abstractive SCM",
        "icon": "$(cloud-download)"
      },
      {
        "command": "abstractiveScm.pullRebase",
        "title": "Pull with Rebase",
        "category": "Abstractive SCM",
        "icon": "$(repo-pull)"
      },
      {
        "command": "abstractiveScm.push",
        "title": "Push",
        "category": "Abstractive SCM",
        "icon": "$(repo-push)"
      },
      {
        "command": "abstractiveScm.checkoutBranch",
        "title": "Checkout Branch...",
        "category": "Abstractive SCM",
        "icon": "$(git-branch)"
      },
      {
        "command": "abstractiveScm.createBranch",
        "title": "New Branch...",
        "category": "Abstractive SCM",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "abstractiveScm.deleteBranch",
        "title": "Delete Branch...",
        "category": "Abstractive SCM",
        "icon": "$(trash)"
      },
      {
        "command": "abstractiveScm.compareWithBranch",
        "title": "Compare With Current Branch",
        "category": "Abstractive SCM",
        "icon": "$(git-compare)"
      },
      {
        "command": "abstractiveScm.stashChanges",
        "title": "Shelve Changes...",
        "category": "Abstractive SCM",
        "icon": "$(archive)"
      },
      {
        "command": "abstractiveScm.applyStash",
        "title": "Unshelve",
        "category": "Abstractive SCM",
        "icon": "$(archive)"
      },
      {
        "command": "abstractiveScm.popStash",
        "title": "Unshelve and Remove",
        "category": "Abstractive SCM",
        "icon": "$(repo-pull)"
      },
      {
        "command": "abstractiveScm.dropStash",
        "title": "Delete Shelf",
        "category": "Abstractive SCM",
        "icon": "$(trash)"
      },
      {
        "command": "abstractiveScm.showLog",
        "title": "Show Git Log",
        "category": "Abstractive SCM",
        "icon": "$(git-branch)"
      },
      {
        "command": "abstractiveScm.openToolWindow",
        "title": "Open SCM Tool Window",
        "category": "Abstractive SCM",
        "icon": "$(window)"
      },
      {
        "command": "abstractiveScm.showCommitFiles",
        "title": "Show Changed Files",
        "category": "Abstractive SCM",
        "icon": "$(list-tree)"
      },
      {
        "command": "abstractiveScm.copyCommitHash",
        "title": "Copy Commit Hash",
        "category": "Abstractive SCM",
        "icon": "$(copy)"
      },
      {
        "command": "abstractiveScm.showFileHistory",
        "title": "Show File History",
        "category": "Abstractive SCM",
        "icon": "$(history)"
      },
      {
        "command": "abstractiveScm.createChangelist",
        "title": "New Changelist...",
        "category": "Abstractive SCM",
        "icon": "$(new-folder)"
      },
      {
        "command": "abstractiveScm.moveToChangelist",
        "title": "Move to Changelist...",
        "category": "Abstractive SCM",
        "icon": "$(move)"
      },
      {
        "command": "abstractiveScm.deleteChangelist",
        "title": "Delete Changelist",
        "category": "Abstractive SCM",
        "icon": "$(trash)"
      },
      {
        "command": "abstractiveScm.openDiff",
        "title": "Show Diff",
        "category": "Abstractive SCM",
        "icon": "$(diff)"
      },
      {
        "command": "abstractiveScm.openFile",
        "title": "Open File",
        "category": "Abstractive SCM",
        "icon": "$(go-to-file)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "abstractiveScm",
          "title": "Abstractive SCM",
          "icon": "media/activity-board-v3.svg"
        }
      ],
      "panel": [
        {
          "id": "abstractiveScmPanel",
          "title": "SCM",
          "icon": "media/activity-board-v3.svg"
        }
      ]
    },
    "views": {
      "abstractiveScm": [
        {
          "id": "abstractiveScm.changes",
          "name": "Local Changes"
        },
        {
          "id": "abstractiveScm.branches",
          "name": "Branches"
        },
        {
          "id": "abstractiveScm.log",
          "name": "Log"
        },
        {
          "id": "abstractiveScm.stashes",
          "name": "Shelves"
        }
      ],
      "abstractiveScmPanel": [
        {
          "type": "webview",
          "id": "abstractiveScm.toolWindow",
          "name": "SCM"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "abstractiveScm.refresh",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@1"
        },
        {
          "command": "abstractiveScm.commit",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@2"
        },
        {
          "command": "abstractiveScm.stageAll",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@2.1"
        },
        {
          "command": "abstractiveScm.unstageAll",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@2.2"
        },
        {
          "command": "abstractiveScm.pullRebase",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@3"
        },
        {
          "command": "abstractiveScm.push",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@4"
        },
        {
          "command": "abstractiveScm.stashChanges",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@5"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "abstractiveScm.openDiff",
          "when": "scmProvider == abstractiveScm",
          "group": "navigation@1"
        },
        {
          "command": "abstractiveScm.stage",
          "when": "scmProvider == abstractiveScm && (scmResourceGroup == abstractiveScm.unstaged || scmResourceGroup == abstractiveScm.untracked || scmResourceGroup == abstractiveScm.conflicts)",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.unstage",
          "when": "scmProvider == abstractiveScm && scmResourceGroup == abstractiveScm.staged",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.revert",
          "when": "scmProvider == abstractiveScm",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "abstractiveScm.refresh",
          "when": "view == abstractiveScm.changes || view == abstractiveScm.branches || view == abstractiveScm.log || view == abstractiveScm.stashes",
          "group": "navigation@1"
        },
        {
          "command": "abstractiveScm.toggleTreeView",
          "when": "view == abstractiveScm.changes || view == abstractiveScm.branches",
          "group": "navigation@1.05"
        },
        {
          "command": "abstractiveScm.stageAll",
          "when": "view == abstractiveScm.changes",
          "group": "navigation@1.1"
        },
        {
          "command": "abstractiveScm.unstageAll",
          "when": "view == abstractiveScm.changes",
          "group": "navigation@1.2"
        },
        {
          "command": "abstractiveScm.commit",
          "when": "view == abstractiveScm.changes",
          "group": "navigation@2"
        },
        {
          "command": "abstractiveScm.createChangelist",
          "when": "view == abstractiveScm.changes",
          "group": "navigation@3"
        },
        {
          "command": "abstractiveScm.stashChanges",
          "when": "view == abstractiveScm.changes",
          "group": "navigation@4"
        },
        {
          "command": "abstractiveScm.createBranch",
          "when": "view == abstractiveScm.branches",
          "group": "navigation@2"
        },
        {
          "command": "abstractiveScm.showLog",
          "when": "view == abstractiveScm.log",
          "group": "navigation@2"
        },
        {
          "command": "abstractiveScm.stashChanges",
          "when": "view == abstractiveScm.stashes",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "abstractiveScm.deleteChangelist",
          "when": "view == abstractiveScm.changes && viewItem == changelist.custom",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.stageGroup",
          "when": "view == abstractiveScm.changes && (viewItem == changesGroup.untracked || viewItem == changesGroup.unstaged || viewItem == changesGroup.conflicts)",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.unstageGroup",
          "when": "view == abstractiveScm.changes && viewItem == changesGroup.staged",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.openDiff",
          "when": "view == abstractiveScm.changes && (viewItem == change.staged || viewItem == change.unstaged || viewItem == change.untracked || viewItem == change.conflicts)",
          "group": "navigation@1"
        },
        {
          "command": "abstractiveScm.showFileHistory",
          "when": "view == abstractiveScm.changes && (viewItem == change.staged || viewItem == change.unstaged || viewItem == change.untracked || viewItem == change.conflicts)",
          "group": "navigation@2"
        },
        {
          "command": "abstractiveScm.moveToChangelist",
          "when": "view == abstractiveScm.changes && (viewItem == change.staged || viewItem == change.unstaged || viewItem == change.untracked || viewItem == change.conflicts)",
          "group": "navigation@3"
        },
        {
          "command": "abstractiveScm.stage",
          "when": "view == abstractiveScm.changes && (viewItem == change.unstaged || viewItem == change.untracked || viewItem == change.conflicts)",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.unstage",
          "when": "view == abstractiveScm.changes && viewItem == change.staged",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.revert",
          "when": "view == abstractiveScm.changes && (viewItem == change.staged || viewItem == change.unstaged || viewItem == change.untracked || viewItem == change.conflicts)",
          "group": "inline@2"
        },
        {
          "command": "abstractiveScm.checkoutBranch",
          "when": "view == abstractiveScm.branches && (viewItem == branch || viewItem == remoteBranch)",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.compareWithBranch",
          "when": "view == abstractiveScm.branches && (viewItem == branch || viewItem == remoteBranch)",
          "group": "inline@2"
        },
        {
          "command": "abstractiveScm.deleteBranch",
          "when": "view == abstractiveScm.branches && viewItem == branch",
          "group": "inline@3"
        },
        {
          "command": "abstractiveScm.applyStash",
          "when": "view == abstractiveScm.stashes && viewItem == stash",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.popStash",
          "when": "view == abstractiveScm.stashes && viewItem == stash",
          "group": "inline@2"
        },
        {
          "command": "abstractiveScm.dropStash",
          "when": "view == abstractiveScm.stashes && viewItem == stash",
          "group": "inline@3"
        },
        {
          "command": "abstractiveScm.showCommitFiles",
          "when": "view == abstractiveScm.log && viewItem == commit",
          "group": "inline@1"
        },
        {
          "command": "abstractiveScm.copyCommitHash",
          "when": "view == abstractiveScm.log && viewItem == commit",
          "group": "inline@2"
        }
      ],
      "editor/context": [
        {
          "command": "abstractiveScm.showFileHistory",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        }
      ],
      "explorer/context": [
        {
          "command": "abstractiveScm.showFileHistory",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@10"
        }
      ]
    },
    "keybindings": [
      {
        "command": "abstractiveScm.commit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "abstractiveScm.refresh",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ],
    "configuration": {
      "title": "Abstractive SCM",
      "properties": {
        "abstractiveScm.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh Git state when workspace files change."
        },
        "abstractiveScm.commitSignoff": {
          "type": "boolean",
          "default": false,
          "description": "Add Signed-off-by trailer to commits made from Abstractive SCM."
        },
        "abstractiveScm.maxLogEntries": {
          "type": "number",
          "default": 75,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum number of commits shown in the Log view."
        },
        "abstractiveScm.enableSourceControlProvider": {
          "type": "boolean",
          "default": false,
          "description": "Register Abstractive SCM as a separate Source Control provider. This duplicates the repository beside VS Code's built-in Git provider."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  }
}
